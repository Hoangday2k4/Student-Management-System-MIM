  padding: 12px;
  border-radius: 8px;
  background: #f4f7fc;
  color: #607086;
}

.table-scroll {
  overflow: auto;
  min-height: 0;
  flex: 1;
  max-height: 380px;
}

.result-table {
  width: 100%;
  border-collapse: collapse;
}

.result-table th,
.result-table td {
  border-bottom: 1px solid #e3e9f2;
