{
  "info": {
    "name": "Student Management API - Regression",
    "_postman_id": "sm-api-regression",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "{{INTEGRATION_BASE_URL}}" },
    { "key": "admin_user", "value": "admin" },
    { "key": "admin_pass", "value": "123456" },
    { "key": "teacher_user", "value": "T001" },
    { "key": "teacher_pass", "value": "123456" },
    { "key": "student_user", "value": "S001" },
    { "key": "student_pass", "value": "123456" },
    { "key": "session_admin", "value": "" },
    { "key": "session_teacher", "value": "" },
    { "key": "session_student", "value": "" },
    { "key": "token_admin", "value": "" },
    { "key": "token_teacher", "value": "" },
    { "key": "token_student", "value": "" },
    { "key": "invalid_token", "value": "invalid.token.value" },
    { "key": "expired_token", "value": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.expired.signature" }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Collection-level auth header helper: prefer bearer token, else session cookie based on 'role' env var",
          "var role = pm.environment.get('role') || 'admin';",
          "function headerForRole(r){",
          "  if (r === 'admin') return {tokenKey: 'token_admin', cookieKey: 'session_admin'};",
          "  if (r === 'teacher') return {tokenKey: 'token_teacher', cookieKey: 'session_teacher'};",
          "  return {tokenKey: 'token_student', cookieKey: 'session_student'};",
          "}",
          "var keys = headerForRole(role);",
          "var token = pm.environment.get(keys.tokenKey);",
          "if (token && token !== '') {",
          "  pm.request.headers.add({key: 'Authorization', value: 'Bearer ' + token});",
          "} else {",
          "  var cookie = pm.environment.get(keys.cookieKey);",
          "  if (cookie && cookie !== '') { pm.request.headers.add({key: 'Cookie', value: cookie}); }",
          "}",
          "// allow tests to override by setting pm.environment.set('auth_skip','true')",
          "if (pm.environment.get('auth_skip') === 'true') { pm.request.headers.remove('Authorization'); pm.request.headers.remove('Cookie'); }"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth / Login - Admin (session cookie)",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            { "key": "login_id", "value": "{{admin_user}}" },
            { "key": "password", "value": "{{admin_pass}}" }
          ]
        },
        "url": { "raw": "{{base_url}}/login.php", "host": ["{{base_url}}"], "path": ["login.php"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('login returns 200 or 302', function(){",
              "  pm.expect(pm.response.code).to.be.oneOf([200,302]);",
              "});",
              "var setCookie = pm.response.headers.get('Set-Cookie');",
              "if (setCookie) {",
              "  var m = setCookie.match(/PHPSESSID=[^;]+/);",
              "  if (m) { pm.environment.set('session_admin', m[0]); }",
              "}",
              "try {",
              "  var j = pm.response.json();",
              "  if (j && j.token) { pm.environment.set('token_admin', j.token); }",
              "} catch(e) {}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Auth / Login - Teacher (session cookie)",
      "request": {
        "method": "POST",
        "body": { "mode": "urlencoded", "urlencoded": [ { "key": "login_id", "value": "{{teacher_user}}" }, { "key": "password", "value": "{{teacher_pass}}" } ] },
        "url": { "raw": "{{base_url}}/login.php", "host": ["{{base_url}}"], "path": ["login.php"] }
      },
      "event": [ { "listen": "test", "script": { "exec": [ "pm.test('teacher login sets cookie', function(){ pm.expect(pm.response.code).to.be.oneOf([200,302]); });", "var sc = pm.response.headers.get('Set-Cookie'); if (sc) { var m = sc.match(/PHPSESSID=[^;]+/); if (m) pm.environment.set('session_teacher', m[0]); }" ], "type": "text/javascript" } } ]
    },
    {
      "name": "Auth / Login - Student (session cookie)",
      "request": { "method": "POST", "body": { "mode": "urlencoded", "urlencoded": [ { "key": "login_id", "value": "{{student_user}}" }, { "key": "password", "value": "{{student_pass}}" } ] }, "url": { "raw": "{{base_url}}/login.php", "host": ["{{base_url}}"], "path": ["login.php"] } },
      "event": [ { "listen": "test", "script": { "exec": [ "pm.test('student login sets cookie', function(){ pm.expect(pm.response.code).to.be.oneOf([200,302]); });", "var sc = pm.response.headers.get('Set-Cookie'); if (sc) { var m = sc.match(/PHPSESSID=[^;]+/); if (m) pm.environment.set('session_student', m[0]); }" ], "type": "text/javascript" } } ]
    },
    {
      "name": "Admin - List Students (pagination)",
      "request": {
        "method": "GET",
        "header": [ { "key": "Cookie", "value": "{{session_admin}}" } ],
        "url": { "raw": "{{base_url}}/student.php?page=1&per_page=10", "host": ["{{base_url}}"], "path": ["student.php"], "query": [ { "key": "page", "value": "1" }, { "key": "per_page", "value": "10" } ] }
      },
      "event": [ { "listen": "test", "script": { "exec": [ "pm.test('status is 200', function(){ pm.expect(pm.response.code).to.equal(200); });", "try { var j = pm.response.json(); if (Array.isArray(j)) { pm.test('page length <= per_page', function(){ pm.expect(j.length).to.be.at.most(10); }); } } catch(e) {}" ], "type": "text/javascript" } } ]
    },
    {
      "name": "Admin - Create Student (CRUD)",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Cookie", "value": "{{session_admin}}" } ],
        "body": { "mode": "raw", "raw": "{\n  \"student_code\": \"STU-{{guid}}\",\n  \"full_name\": \"Integration Student {{guid}}\",\n  \"class_name\": \"CTK42\",\n  \"gender\": \"Nam\",\n  \"status\": \"Dang hoc\",\n  \"email\": \"student.{{guid}}@example.test\"\n}" },
        "url": { "raw": "{{base_url}}/student.php", "host": ["{{base_url}}"], "path": ["student.php"] }
      },
      "event": [ { "listen": "prerequest", "script": { "exec": [ "pm.variables.set('guid', Math.random().toString(36).substring(2,8));" ], "type": "text/javascript" } }, { "listen": "test", "script": { "exec": [ "pm.test('created or conflict', function(){ pm.expect(pm.response.code).to.be.oneOf([201,409]); });", "try { var j = pm.response.json(); if (j && j.data && j.data.student_code) pm.environment.set('last_created_student', j.data.student_code); } catch(e) {}" ], "type": "text/javascript" } } ]
    },
    {
      "name": "Negative - SQL Injection (create student)",
      "request": { "method": "POST", "header": [ { "key": "Content-Type", "value": "application/json" }, { "key": "Cookie", "value": "{{session_admin}}" } ], "body": { "mode": "raw", "raw": "{\n  \"student_code\": \"S_INJ_{{guid}}\",\n  \"full_name\": \"x' OR '1'='1\",\n  \"class_name\": \"CTK42\",\n  \"gender\": \"Nam\",\n  \"status\": \"Dang hoc\",\n  \"email\": \"inj.{{guid}}@example.test\"\n}" }, "url": { "raw": "{{base_url}}/student.php", "host": ["{{base_url}}"], "path": ["student.php"] } },
      "event": [ { "listen": "prerequest", "script": { "exec": [ "pm.variables.set('guid', Math.random().toString(36).substring(2,8));" ], "type": "text/javascript" } }, { "listen": "test", "script": { "exec": [ "pm.test('does not return 500', function(){ pm.expect(pm.response.code).to.not.equal(500); });" ], "type": "text/javascript" } } ]
    },
    {
      "name": "Negative - Invalid JWT Header",
      "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{invalid_token}}" } ], "url": { "raw": "{{base_url}}/student.php", "host": ["{{base_url}}"], "path": ["student.php"] } },
      "event": [ { "listen": "test", "script": { "exec": [ "pm.test('invalid token returns 401/403 or server ignores it', function(){ pm.expect(pm.response.code).to.be.oneOf([401,403,200]); });" ], "type": "text/javascript" } } ]
    },
    {
      "name": "Negative - Expired JWT Header",
      "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{expired_token}}" } ], "url": { "raw": "{{base_url}}/student.php", "host": ["{{base_url}}"], "path": ["student.php"] } },
      "event": [ { "listen": "test", "script": { "exec": [ "pm.test('expired token returns 401/403 or server ignores it', function(){ pm.expect(pm.response.code).to.be.oneOf([401,403,200]); });" ], "type": "text/javascript" } } ]
    },
    {
      "name": "Rate Limit - repeated requests",
      "request": { "method": "GET", "header": [ { "key": "Cookie", "value": "{{session_student}}" } ], "url": { "raw": "{{base_url}}/home", "host": ["{{base_url}}"], "path": ["home"] } },
      "event": [ { "listen": "test", "script": { "exec": [ "var url = '{{base_url}}/home';", "var results = [];", "for (var i=0;i<8;i++){ (function(i){ pm.sendRequest(url, function (err, res) { results.push(res.code); if (i===7){ pm.test('rate limit behavior observed', function(){ pm.expect(results.some(function(s){return s===429;} ) || results.every(function(s){return s===200;})).to.be.true; }); } }); })(i); }" ], "type": "text/javascript" } } ]
    },
    {
      "name": "File Upload - student import",
      "request": {
        "method": "POST",
        "header": [ { "key": "Cookie", "value": "{{session_admin}}" } ],
        "body": {
          "mode": "formdata",
          "formdata": [
            { "key": "file", "type": "file", "src": "../files/sample.csv" }
          ]
        },
        "url": { "raw": "{{base_url}}/student_import.php", "host": ["{{base_url}}"], "path": ["student_import.php"] }
      },
      "event": [ { "listen": "test", "script": { "exec": [ "pm.test('upload did not crash', function(){ pm.expect(pm.response.code).to.not.equal(500); });" ], "type": "text/javascript" } } ]
    },
    {
      "name": "Edge - Delete non-existent student",
      "request": { "method": "DELETE", "header": [ { "key": "Cookie", "value": "{{session_admin}}" } ], "url": { "raw": "{{base_url}}/student.php?student_code=NOT-EXIST-{{guid}}", "host": ["{{base_url}}"], "path": ["student.php"], "query": [ { "key": "student_code", "value": "NOT-EXIST-{{guid}}" } ] },
      "event": [ { "listen": "prerequest", "script": { "exec": [ "pm.variables.set('guid', Math.random().toString(36).substring(2,8));" ], "type": "text/javascript" } }, { "listen": "test", "script": { "exec": [ "pm.test('delete non-existent returns 4xx', function(){ pm.expect(pm.response.code).to.be.within(400,499); });" ], "type": "text/javascript" } } ]
    },
    {
      "name": "Auth / Obtain JWT (best-effort)",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": { "mode": "raw", "raw": "{ \"login_id\": \"{{admin_user}}\", \"password\": \"{{admin_pass}}\" }" },
        "url": { "raw": "{{base_url}}/login_token.php", "host": ["{{base_url}}"], "path": ["login_token.php"] }
      },
      "event": [
        { "listen": "test", "script": { "type": "text/javascript", "exec": [
          "pm.test('attempt token obtain (200/201 or 404)', function(){ pm.expect(pm.response.code).to.be.oneOf([200,201,404,400]); });",
          "try { var j = pm.response.json(); if (j && j.token) { pm.environment.set('token_admin', j.token); } } catch(e) {}",
          "if (!pm.environment.get('token_admin')) {",
          "  pm.sendRequest({ url: pm.environment.get('base_url') + '/token.php', method: 'POST', header: { 'Content-Type': 'application/json' }, body: JSON.stringify({ login_id: pm.environment.get('admin_user'), password: pm.environment.get('admin_pass') }) }, function (err, res) { if (res && res.json && res.json.token) pm.environment.set('token_admin', res.json.token); });",
          "}"
        ] } }
      ]
    },
    {
      "name": "Auth / Refresh Token (best-effort)",
      "request": {
        "method": "POST",
        "header": [ { "key": "Content-Type", "value": "application/json" } ],
        "body": { "mode": "raw", "raw": "{ \"refresh_token\": \"{{refresh_token}}\" }" },
        "url": { "raw": "{{base_url}}/refresh_token.php", "host": ["{{base_url}}"], "path": ["refresh_token.php"] }
      },
      "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('refresh token endpoint returns 200 or 404', function(){ pm.expect(pm.response.code).to.be.oneOf([200,404,400]); });", "try { var j = pm.response.json(); if (j && j.token) pm.environment.set('token_admin', j.token); } catch(e) {}" ] } } ]
    },
    {
      "name": "Role Matrix - Core endpoints (run per role)",
      "request": {
        "method": "GET",
        "url": { "raw": "{{base_url}}/student.php", "host": ["{{base_url}}"], "path": ["student.php"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var roles = ['admin','teacher','student'];",
              "var results = [];",
              "var done = 0;",
              "roles.forEach(function(r){",
              "  var cookie = (r==='admin'? pm.environment.get('session_admin') : (r==='teacher'? pm.environment.get('session_teacher') : pm.environment.get('session_student')) );",
              "  var token = (r==='admin'? pm.environment.get('token_admin') : (r==='teacher'? pm.environment.get('token_teacher') : pm.environment.get('token_student')) );",
              "  var headers = {}; if (token) { headers['Authorization'] = 'Bearer ' + token; } else if (cookie) { headers['Cookie'] = cookie; }",
              "  pm.sendRequest({ url: pm.environment.get('base_url') + '/student.php', method: 'GET', header: headers }, function (err, res){",
              "    results.push({ role: r, code: res && res.code ? res.code : (err? 0: 0) });",
              "    done++;",
              "    if (done === roles.length){",
              "      var adminRes = results.find(function(x){return x.role==='admin'});",
              "      pm.test('admin should have successful access to student list', function(){ pm.expect(adminRes.code).to.be.within(200,299); });",
              "      pm.environment.set('roleMatrixResults', JSON.stringify(results));",
              "    }",
              "  });",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Pagination - metadata and boundaries",
      "request": {
        "method": "GET",
        "header": [ { "key": "Cookie", "value": "{{session_admin}}" } ],
        "url": { "raw": "{{base_url}}/student.php?page=9999&per_page=50", "host": ["{{base_url}}"], "path": ["student.php"], "query": [ { "key": "page", "value": "9999" }, { "key": "per_page", "value": "50" } ] }
      },
      "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('pagination returns 2xx or 4xx for out-of-range page', function(){ pm.expect(pm.response.code).to.be.oneOf([200,400,404]); });", "try { var j = pm.response.json(); pm.test('pagination metadata present or array', function(){ pm.expect(Array.isArray(j) || j.total !== undefined || pm.response.headers.has('X-Total-Count')).to.be.true; }); } catch(e){}" ] } } ]
    },
    {
      "name": "Auth - Token Expiry Simulation (use expired token)",
      "request": { "method": "GET", "header": [ { "key": "Authorization", "value": "Bearer {{expired_token}}" } ], "url": { "raw": "{{base_url}}/home", "host": ["{{base_url}}"], "path": ["home"] } },
      "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('expired token should return 401/403 or server ignores it', function(){ pm.expect(pm.response.code).to.be.oneOf([401,403,200]); });" ] } } ]
    }
    ,
    {
      "name": "File Upload - malformed CSV",
      "request": {
        "method": "POST",
        "header": [ { "key": "Cookie", "value": "{{session_admin}}" } ],
        "body": { "mode": "formdata", "formdata": [ { "key": "file", "type": "file", "src": "../files/malformed.csv" } ] },
        "url": { "raw": "{{base_url}}/student_import.php", "host": ["{{base_url}}"], "path": ["student_import.php"] }
      },
      "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('malformed upload should not crash server', function(){ pm.expect(pm.response.code).to.not.equal(500); });" ] } } ]
    },
    {
      "name": "File Upload - oversized CSV",
      "request": {
        "method": "POST",
        "header": [ { "key": "Cookie", "value": "{{session_admin}}" } ],
        "body": { "mode": "formdata", "formdata": [ { "key": "file", "type": "file", "src": "../files/oversized.csv" } ] },
        "url": { "raw": "{{base_url}}/student_import.php", "host": ["{{base_url}}"], "path": ["student_import.php"] }
      },
      "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('oversized upload handled (200 or 413/400)', function(){ pm.expect(pm.response.code).to.be.oneOf([200,400,413]); });" ] } } ]
    },
    {
      "name": "File Upload - invalid MIME",
      "request": {
        "method": "POST",
        "header": [ { "key": "Cookie", "value": "{{session_admin}}" } ],
        "body": { "mode": "formdata", "formdata": [ { "key": "file", "type": "file", "src": "../files/invalid_mime.txt" } ] },
        "url": { "raw": "{{base_url}}/student_import.php", "host": ["{{base_url}}"], "path": ["student_import.php"] }
      },
      "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('invalid mime handled', function(){ pm.expect(pm.response.code).to.be.oneOf([200,400]); });" ] } } ]
    },
    {
      "name": "File Upload - empty file",
      "request": {
        "method": "POST",
        "header": [ { "key": "Cookie", "value": "{{session_admin}}" } ],
        "body": { "mode": "formdata", "formdata": [ { "key": "file", "type": "file", "src": "../files/empty.csv" } ] },
        "url": { "raw": "{{base_url}}/student_import.php", "host": ["{{base_url}}"], "path": ["student_import.php"] }
      },
      "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('empty upload handled', function(){ pm.expect(pm.response.code).to.be.oneOf([200,400]); });" ] } } ]
    }
  ]
}
