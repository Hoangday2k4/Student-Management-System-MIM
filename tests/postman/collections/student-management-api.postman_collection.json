{
  "info": {
    "name": "Student Management API - Minimal",
    "_postman_id": "sm-api-minimal",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "{{INTEGRATION_BASE_URL}}" },
    { "key": "admin_user", "value": "admin" },
    { "key": "admin_pass", "value": "123456" },
    { "key": "session_admin", "value": "" }
  ],
  "item": [
    {
      "name": "Auth / Login - Admin (session cookie)",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            { "key": "login_id", "value": "{{admin_user}}" },
            { "key": "password", "value": "{{admin_pass}}" }
          ]
        },
        "url": { "raw": "{{base_url}}/login.php", "host": ["{{base_url}}"], "path": ["login.php"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('login returns 200 or 302', function(){ pm.expect(pm.response.code).to.be.oneOf([200,302]); });",
              "var setCookie = pm.response.headers.get('Set-Cookie'); if (setCookie) { var m = setCookie.match(/PHPSESSID=[^;]+/); if (m) pm.environment.set('session_admin', m[0]); }"
            ]
          }
        }
      ]
    },
    {
      "name": "Admin - List Students (pagination)",
      "request": {
        "method": "GET",
        "header": [ { "key": "Cookie", "value": "{{session_admin}}" } ],
        "url": { "raw": "{{base_url}}/student.php?page=1&per_page=10", "host": ["{{base_url}}"], "path": ["student.php"], "query": [ { "key": "page", "value": "1" }, { "key": "per_page", "value": "10" } ] }
      },
      "event": [ { "listen": "test", "script": { "type": "text/javascript", "exec": [ "pm.test('status is 200 or 4xx', function(){ pm.expect(pm.response.code).to.be.oneOf([200,400,401,403,404]); });" ] } } ]
    }
  ]
}
